<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2" name="Smoke Test Alex" parallel="tests">
    <test name="Chrome">
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.CompleteTest">
            <methods>
                <include name="checkOverview"/>
            </methods>
            </class>
            <parameter name="browser" value="chrome"/>
        </classes>
    </test> <!-- Test -->
    <test name="FireFox">
        <classes>
            <class name="tests.CheckOutTests"/>
            <class name="tests.CartTest">
                <methods>
                    <include name="addProductToCart"/>
                </methods>
        </class>
            <parameter name="browser" value="firefox"/>
        </classes>
    </test> <!-- Test -->
</suite>
